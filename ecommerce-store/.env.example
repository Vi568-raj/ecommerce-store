# ==========================================
# Environment Variables - copy this file to ".env"
# and fill in your own values before running the app
# ==========================================

# Server port
PORT=5000

# MongoDB connection string
# Local:  mongodb://127.0.0.1:27017/ecommerce_store
# Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/ecommerce_store
MONGO_URI=mongodb://127.0.0.1:27017/ecommerce_store

# JWT secret used to sign auth tokens - use a long random string in production
JWT_SECRET=replace_this_with_a_long_random_secret_key
JWT_EXPIRES_IN=7d

# Environment: development | production
NODE_ENV=development
